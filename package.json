{
  "name": "productprice",
  "version": "1.0.0",
  "description": "Compare product prices across JB Hi-Fi, The Good Guys, and Harvey Norman",
  "type": "module",
  "scripts": {
    "start": "node server.mjs",
    "dev": "node server.mjs",
